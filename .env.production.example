# Production-like deployment template.
# Copy to .env.production, replace every placeholder, and never commit real values.

NODE_ENV=production

POSTGRES_USER=<database-user>
POSTGRES_PASSWORD=<database-password>
POSTGRES_DB=mediguard

API_PORT=4000
DATABASE_URL=postgresql://<database-user>:<database-password>@postgres:5432/mediguard?schema=public
JWT_ACCESS_SECRET=<at-least-32-random-characters>
JWT_REFRESH_SECRET=<different-at-least-32-random-characters>
CORS_ORIGIN=https://<your-web-domain>
SWAGGER_ENABLED=false
SWAGGER_USERNAME=<required-if-swagger-enabled>
SWAGGER_PASSWORD=<required-if-swagger-enabled-min-12-chars>
FILE_STORAGE_DIR=storage/uploads

NEXT_PUBLIC_API_URL=https://<your-api-domain>
