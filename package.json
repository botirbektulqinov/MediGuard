{
  "name": "mediguard",
  "version": "0.1.0",
  "private": true,
  "description": "Secure clinic operations platform with appointment queue, patient portal, QA Center, and Security Center.",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "corepack pnpm -r typecheck",
    "test": "corepack pnpm -r test",
    "test:integration": "corepack pnpm --filter @mediguard/api test:integration",
    "test:e2e": "corepack pnpm --filter @mediguard/web test:e2e",
    "build": "corepack pnpm -r build",
    "prisma:validate": "corepack pnpm --filter @mediguard/api prisma validate",
    "dev": "corepack pnpm -r --parallel dev",
    "dev:api": "corepack pnpm --filter @mediguard/api start:dev",
    "dev:web": "corepack pnpm --filter @mediguard/web dev"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.15",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10"
    }
  }
}
