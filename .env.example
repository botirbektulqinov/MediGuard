# Shared
NODE_ENV=development

# Docker Compose
POSTGRES_USER=mediguard
POSTGRES_PASSWORD=mediguard_dev_password
POSTGRES_DB=mediguard

# API
API_PORT=4000
DATABASE_URL=postgresql://mediguard:mediguard_dev_password@postgres:5432/mediguard?schema=public
JWT_ACCESS_SECRET=replace-with-a-long-random-development-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-development-secret
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
SWAGGER_ENABLED=true
FILE_STORAGE_DIR=storage/uploads

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
